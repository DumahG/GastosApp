<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="controller.DashboardController"
            prefWidth="900" prefHeight="600">

    <!-- TITULO -->
    <top>
        <VBox style="-fx-background-color: #2C3E50; -fx-padding: 15;">
            <Label text="GastosApp - Control de Gastos Mensuales"
                   style="-fx-text-fill: white; -fx-font-size: 18; -fx-font-weight: bold;"/>
        </VBox>
    </top>

    <!-- CONTENIDO PRINCIPAL -->
    <center>
        <HBox spacing="10" style="-fx-padding: 10;">

            <!-- PANEL IZQUIERDO: Formulario + Dashboard -->
            <VBox spacing="10" prefWidth="280">

                <!-- DASHBOARD RESUMEN -->
                <VBox spacing="6" style="-fx-background-color: #ECF0F1; -fx-padding: 12; -fx-background-radius: 8;">
                    <Label text="Resumen del Mes" style="-fx-font-weight: bold; -fx-font-size: 14;"/>
                    <HBox spacing="5">
                        <Label text="Total gastado:"/>
                        <Label fx:id="lblTotalGastado" text="0" style="-fx-font-weight: bold; -fx-text-fill: red;"/>
                    </HBox>
                    <HBox spacing="5">
                        <Label text="Estimación cierre:"/>
                        <Label fx:id="lblEstimacion" text="0" style="-fx-text-fill: orange;"/>
                    </HBox>
                    <HBox spacing="5">
                        <Label text="Ahorro posible:"/>
                        <Label fx:id="lblAhorro" text="0" style="-fx-text-fill: green;"/>
                    </HBox>
                    <HBox spacing="5">
                        <Label text="Estado:"/>
                        <Label fx:id="lblEstado" text="En control" style="-fx-font-weight: bold;"/>
                    </HBox>
                    <HBox spacing="5">
                        <Label text="Presupuesto:"/>
                        <Label fx:id="lblPresupuesto" text="0" style="-fx-text-fill: blue; -fx-font-weight: bold;"/>
                    </HBox>
                    <HBox spacing="5" style="-fx-padding: 5 0 0 0;">
                        <ComboBox fx:id="cmbMes" prefWidth="120" promptText="Mes"/>
                        <ComboBox fx:id="cmbAnio" prefWidth="90" promptText="Año"/>
                        <Button text="Consultar"
                                onAction="#consultarMes"
                                style="-fx-background-color: #2980B9; -fx-text-fill: white; -fx-background-radius: 5;"/>
                    </HBox>
                    <HBox spacing="5" style="-fx-padding: 5 0 0 0;">
                        <TextField fx:id="txtPresupuesto" promptText="Nuevo presupuesto" prefWidth="150"/>
                        <Button text="Guardar" onAction="#guardarPresupuesto"
                                style="-fx-background-color: #2980B9; -fx-text-fill: white; -fx-background-radius: 5;"/>
                    </HBox>
                </VBox>

                <!-- FORMULARIO REGISTRO -->
                <VBox spacing="8" style="-fx-background-color: #EBF5FB; -fx-padding: 12; -fx-background-radius: 8;">
                    <Label text="Registrar Gasto" style="-fx-font-weight: bold; -fx-font-size: 14; -fx-text-fill: black;"/>

                    <Label text="Monto ($):" style="-fx-text-fill: black;"/>
                    <TextField fx:id="txtMonto" promptText="Ej: 5990"/>

                    <Label text="Tienda / Comercio:" style="-fx-text-fill: black;"/>
                    <TextField fx:id="txtTienda" promptText="Ej: Jumbo Maipú"/>

                    <Label text="Ubicación:" style="-fx-text-fill: black;"/>
                    <TextField fx:id="txtUbicacion" promptText="Ej: Av. Pajaritos 3000"/>

                    <Label text="Categoría:" style="-fx-text-fill: black;"/>
                    <ComboBox fx:id="cmbCategoria" prefWidth="250" promptText="Selecciona categoría"/>

                    <Button text="Registrar Gasto"
                            onAction="#registrarGasto"
                            prefWidth="250"
                            style="-fx-background-color: #2980B9; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5;"/>
                </VBox>
            </VBox>

            <!-- CATEGORIAS PERSONALIZADAS -->
            <VBox spacing="8" style="-fx-background-color: #EBF5FB; -fx-padding: 12; -fx-background-radius: 8;">
                <Label text="Gestionar Categorías"
                       style="-fx-font-weight: bold; -fx-font-size: 14;"/>

                <Label text="Nueva categoría:"/>
                <TextField fx:id="txtNuevaCategoria"
                           promptText="Ej: Mascotas"/>

                <Button text="Agregar Categoría"
                        onAction="#agregarCategoria"
                        prefWidth="250"
                        style="-fx-background-color: green; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5;"/>

                <Label text="Categorías personalizadas:"/>
                <ComboBox fx:id="cmbEliminarCategoria"
                          prefWidth="250"
                          promptText="Selecciona para eliminar"/>

                <Button text="Eliminar Categoría"
                        onAction="#eliminarCategoria"
                        prefWidth="250"
                        style="-fx-background-color: orange; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5;"/>
            </VBox>

            <!-- PANEL DERECHO: Historial -->
            <VBox spacing="8" HBox.hgrow="ALWAYS">
                <Label text="Historial de Gastos del Mes"
                       style="-fx-font-weight: bold; -fx-font-size: 14;"/>

                <TableView fx:id="tablaGastos" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colId" text="ID" prefWidth="40"/>
                        <TableColumn fx:id="colMonto" text="Monto $" prefWidth="90"/>
                        <TableColumn fx:id="colTienda" text="Tienda" prefWidth="130"/>
                        <TableColumn fx:id="colCategoria" text="Categoría" prefWidth="120"/>
                        <TableColumn fx:id="colUbicacion" text="Ubicación" prefWidth="150"/>
                        <TableColumn fx:id="colFecha" text="Fecha/Hora" prefWidth="140"/>
                    </columns>
                </TableView>

                <Button text="Eliminar Gasto Seleccionado"
                        onAction="#eliminarGasto"
                        style="-fx-background-color: red; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5;"/>
            </VBox>

        </HBox>
    </center>

</BorderPane>